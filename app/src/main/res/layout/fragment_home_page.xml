<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <Button
        android:id="@+id/voletsBtn"
        android:layout_width="200dp"
        android:layout_height="150dp"
        android:background="@drawable/bgk"
        android:text="Volets"
        app:layout_constraintBottom_toTopOf="@id/garageBtn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/garageBtn"
        android:layout_width="200dp"
        android:layout_height="150dp"
        android:background="@drawable/bgk"
        android:text="Garage"
        app:layout_constraintBottom_toTopOf="@id/LimieresBtn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/voletsBtn" />

    <Button
        android:id="@+id/LimieresBtn"
        android:layout_width="200dp"
        android:layout_height="150dp"
        android:background="@drawable/bgk"
        android:text="Lumières"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/garageBtn" />

</androidx.constraintlayout.widget.ConstraintLayout>